module Test.Compiler.Parse.Module exposing ( tests )

import Expect exposing (Expectation)
import Test exposing (Test, describe, test, fuzz)
import String.Parser.Advanced as Parser
import Compiler.Parse.Module as PM
import Compiler.Parse.Number as Number
import Compiler.SourcePosition as SourcePosition
import Compiler.Ast.Source as AST
import Compiler.Parse.Context as Context


tests : Test
tests =
    describe "Parse.Module"
        [ test "Empty module" <| \_ ->
            Parser.run PM.parser Context.empty
                """
                module MyModule exposing (..)
                """
                |> expect
                    (AST.Implementation
                        { name =
                            SourcePosition.at
                                { row = 1, col = 8 }
                                { row = 1, col = 16 }
                                "MyModule"
                        , exports = AST.Open
                        , docs = Nothing
                        , requires = []
                        , imports = []
                        , values = []
                        , unions = []
                        , aliases = []
                        , binops = []
                        , effects = AST.NoEffects
                        }
                    )
        , test "Empty module with exposings (valid when parsing)" <| \_ ->
            Parser.run PM.parser Context.empty
                """
                module MyModule exposing ( Model, Msg (..), (==), view )
                """
                |> expect
                    (AST.Implementation
                        { name =
                            SourcePosition.at
                                { row = 1, col = 8 }
                                { row = 1, col = 16 }
                                "MyModule"
                        , exports =
                            AST.Explicit
                                [ AST.ExposedUpper
                                    { name =
                                        SourcePosition.at
                                            { row = 1, col = 28 }
                                            { row = 1, col = 33 }
                                            "Model"
                                    , privacy = AST.Private
                                    }
                                , AST.ExposedUpper
                                    { name =
                                        SourcePosition.at
                                            { row = 1, col = 35 }
                                            { row = 1, col = 38 }
                                            "Msg"
                                    , privacy = AST.Public
                                    }
                                , AST.ExposedOperator <|
                                    SourcePosition.at
                                        { row = 1, col = 46 }
                                        { row = 1, col = 48 }
                                        "=="
                                , AST.ExposedLower <|
                                    SourcePosition.at
                                        { row = 1, col = 51 }
                                        { row = 1, col = 55 }
                                        "view"
                                ]
                        , docs = Nothing
                        , requires = []
                        , imports = []
                        , values = []
                        , unions = []
                        , aliases = []
                        , binops = []
                        , effects = AST.NoEffects
                        }
                    )
        , test "the port keyword is optional (going away in future release)" <| \_ ->
            Parser.run PM.parser Context.empty
                """
                port module PortModule exposing (..)
                """
                |> expect
                    (AST.Implementation
                        { name =
                            SourcePosition.at
                                { row = 1, col = 13 }
                                { row = 1, col = 23 }
                                "PortModule"
                        , exports = AST.Open
                        , docs = Nothing
                        , requires = []
                        , imports = []
                        , values = []
                        , unions = []
                        , aliases = []
                        , binops = []
                        , effects = AST.NoEffects
                        }
                    )
        , test "effect module with defined cmd" <| \_ ->
            Parser.run PM.parser Context.empty
                """
                effect module CmdModule where { command = MyCmd } exposing (..)
                """
                |> expect
                    (AST.Implementation
                        { name =
                            SourcePosition.at
                                { row = 1, col = 15 }
                                { row = 1, col = 24 }
                                "CmdModule"
                        , exports = AST.Open
                        , docs = Nothing
                        , requires = []
                        , imports = []
                        , values = []
                        , unions = []
                        , aliases = []
                        , binops = []
                        , effects =
                            SourcePosition.at
                                { row = 1, col = 43 }
                                { row = 1, col = 48 }
                                "MyCmd"
                                |> AST.Cmd
                                |> AST.Manager
                        }
                    )
        , test "effect module with defined sub" <| \_ ->
            Parser.run PM.parser Context.empty
                """
                effect module SubModule where { subscription = MySub } exposing (..)
                """
                |> expect
                    (AST.Implementation
                        { name =
                            SourcePosition.at
                                { row = 1, col = 15 }
                                { row = 1, col = 24 }
                                "SubModule"
                        , exports = AST.Open
                        , docs = Nothing
                        , requires = []
                        , imports = []
                        , values = []
                        , unions = []
                        , aliases = []
                        , binops = []
                        , effects =
                            SourcePosition.at
                                { row = 1, col = 48 }
                                { row = 1, col = 53 }
                                "MySub"
                                |> AST.Sub
                                |> AST.Manager
                        }
                    )
        , test "effect module with defined fx" <| \_ ->
            Parser.run PM.parser Context.empty
                """
                effect module FxModule where { command = MyCmd, subscription = MySub } exposing (..)
                """
                |> expect
                    (AST.Implementation
                        { name =
                            SourcePosition.at
                                { row = 1, col = 15 }
                                { row = 1, col = 23 }
                                "FxModule"
                        , exports = AST.Open
                        , docs = Nothing
                        , requires = []
                        , imports = []
                        , values = []
                        , unions = []
                        , aliases = []
                        , binops = []
                        , effects =
                            { cmd =
                                SourcePosition.at
                                    { row = 1, col = 42 }
                                    { row = 1, col = 47 }
                                    "MyCmd"
                            , sub =
                                SourcePosition.at
                                    { row = 1, col = 64 }
                                    { row = 1, col = 69 }
                                    "MySub"
                            }
                                |> AST.Fx
                                |> AST.Manager
                        }
                    )
        , test "Docs" <| \_ ->
            Parser.run PM.parser Context.empty
                """
                module MyModule exposing (..)

                {-| The documentation for MyModule
                -}
                """
                |> expect
                    (AST.Implementation
                        { name =
                            SourcePosition.at
                                { row = 1, col = 8 }
                                { row = 1, col = 16 }
                                "MyModule"
                        , exports = AST.Open
                        , docs = Just <|
                            SourcePosition.at
                                { row = 3, col = 1 }
                                { row = 4, col = 3 }
                                " The documentation for MyModule\n"
                        , requires = []
                        , imports = []
                        , values = []
                        , unions = []
                        , aliases = []
                        , binops = []
                        , effects = AST.NoEffects
                        }
                    )
        , test "imports" <| \_ ->
            Parser.run PM.parser Context.empty
                """
                module MyModule exposing (..)

                import Array
                """
                |> expect
                    (AST.Implementation
                        { name =
                            SourcePosition.at
                                { row = 1, col = 8 }
                                { row = 1, col = 16 }
                                "MyModule"
                        , exports = AST.Open
                        , docs = Nothing
                        , requires = []
                        , imports =
                            [ SourcePosition.at
                                { row = 3, col = 1 }
                                { row = 3, col = 13 }
                                { module_ =
                                    SourcePosition.at
                                        { row = 3, col = 8 }
                                        { row = 3, col = 13 }
                                        "Array"
                                , args = []
                                , alias = Nothing
                                , expose = AST.Explicit []
                                }
                            ]
                        , values = []
                        , unions = []
                        , aliases = []
                        , binops = []
                        , effects = AST.NoEffects
                        }
                    )
        , test "imports with alias" <| \_ ->
            Parser.run PM.parser Context.empty
                """
                module MyModule exposing (..)

                import Array as A
                """
                |> expect
                    (AST.Implementation
                        { name =
                            SourcePosition.at
                                { row = 1, col = 8 }
                                { row = 1, col = 16 }
                                "MyModule"
                        , exports = AST.Open
                        , docs = Nothing
                        , requires = []
                        , imports =
                            [ SourcePosition.at
                                { row = 3, col = 1 }
                                { row = 3, col = 18 }
                                { module_ =
                                    SourcePosition.at
                                        { row = 3, col = 8 }
                                        { row = 3, col = 13 }
                                        "Array"
                                , args = []
                                , alias = Just "A"
                                , expose = AST.Explicit []
                                }
                            ]
                        , values = []
                        , unions = []
                        , aliases = []
                        , binops = []
                        , effects = AST.NoEffects
                        }
                    )
        , test "imports with alias and exposing" <| \_ ->
            Parser.run PM.parser Context.empty
                """
                module MyModule exposing (..)

                import Array exposing (..)
                import Nested.Module as N.M exposing (T)
                """
            |> expect
                (AST.Implementation
                    { name =
                        SourcePosition.at
                            { row = 1, col = 8 }
                            { row = 1, col = 16 }
                            "MyModule"
                    , exports = AST.Open
                    , docs = Nothing
                    , requires = []
                    , imports =
                        [ SourcePosition.at
                            { row = 3, col = 1 }
                            { row = 3, col = 27 }
                            { module_ =
                                SourcePosition.at
                                    { row = 3, col = 8 }
                                    { row = 3, col = 13 }
                                    "Array"
                            , args = []
                            , alias = Nothing
                            , expose = AST.Open
                            }
                        , SourcePosition.at
                            { row = 4, col = 1 }
                            { row = 4, col = 41 }
                            { module_ =
                                SourcePosition.at
                                    { row = 4, col = 8 }
                                    { row = 4, col = 21 }
                                    "Nested.Module"
                            , args = []
                            , alias = Just "N.M"
                            , expose =
                                AST.Explicit
                                    [ AST.ExposedUpper
                                        { name =
                                            SourcePosition.at
                                                { row = 4, col = 39 }
                                                { row = 4, col = 40 }
                                                "T"
                                        , privacy = AST.Private
                                        }
                                    ]
                                }
                            ]
                    , values = []
                    , unions = []
                    , aliases = []
                    , binops = []
                    , effects = AST.NoEffects
                    }
                )
        , test "imports end positions" <| \_ ->
            Parser.run PM.parser Context.empty
                """
                module MyModule exposing (..)

                import Array
  
                import Basics exposing
                    (max)
                """
            |> expect
                (AST.Implementation
                    { name =
                        SourcePosition.at
                            { row = 1, col = 8 }
                            { row = 1, col = 16 }
                            "MyModule"
                    , exports = AST.Open
                    , docs = Nothing
                    , requires = []
                    , imports =
                        [ SourcePosition.at
                            { row = 3, col = 1 }
                            { row = 3, col = 13 }
                            { module_ =
                                SourcePosition.at
                                    { row = 3, col = 8 }
                                    { row = 3, col = 13 }
                                    "Array"
                            , args = []
                            , alias = Nothing
                            , expose = AST.Explicit []
                            }
                        , SourcePosition.at
                            { row = 5, col = 1 }
                            { row = 6, col = 10 }
                            { module_ =
                                SourcePosition.at
                                    { row = 5, col = 8 }
                                    { row = 5, col = 14 }
                                    "Basics"
                            , args = []
                            , alias = Nothing
                            , expose =
                                AST.Explicit
                                    [ AST.ExposedLower <|
                                        SourcePosition.at
                                            { row = 6, col = 6 }
                                            { row = 6, col = 9 }
                                            "max"
                                    ]
                            }
                        ]
                    , values = []
                    , unions = []
                    , aliases = []
                    , binops = []
                    , effects = AST.NoEffects
                }
            )
        , test "requires with alias and exposing" <| \_ ->
            Parser.run PM.parser Context.empty
                """
                module MyModule exposing (..)

                require Compare
                require String.Compare as StrC
                require Package exposing (..)

                import Array exposing (..)
                import Nested.Module as N.M exposing (T)
                """
            |> expect
                (AST.Implementation
                    { name =
                        SourcePosition.at
                            { row = 1, col = 8 }
                            { row = 1, col = 16 }
                            "MyModule"
                    , exports = AST.Open
                    , docs = Nothing
                    , requires =
                        [ SourcePosition.at
                            { row = 3, col = 1 }
                            { row = 3, col = 16 }
                            { module_ =
                                SourcePosition.at
                                    { row = 3, col = 9 }
                                    { row = 3, col = 16 }
                                    "Compare"
                            , alias = Nothing
                            , expose = AST.Explicit []
                            }
                        , SourcePosition.at
                            { row = 4, col = 1 }
                            { row = 4, col = 31 }
                            { module_ =
                                SourcePosition.at
                                    { row = 4, col = 9 }
                                    { row = 4, col = 23 }
                                    "String.Compare"
                            , alias = Just "StrC"
                            , expose = AST.Explicit []
                            }
                        , SourcePosition.at
                            { row = 5, col = 1 }
                            { row = 5, col = 30 }
                            { module_ =
                                SourcePosition.at
                                    { row = 5, col = 9 }
                                    { row = 5, col = 16 }
                                    "Package"
                            , alias = Nothing
                            , expose = AST.Open
                            }
                        ]
                    , imports =
                        [ SourcePosition.at
                            { row = 7, col = 1 }
                            { row = 7, col = 27 }
                            { module_ =
                                SourcePosition.at
                                    { row = 7, col = 8 }
                                    { row = 7, col = 13 }
                                    "Array"
                            , args = []
                            , alias = Nothing
                            , expose = AST.Open
                            }
                        , SourcePosition.at
                            { row = 8, col = 1 }
                            { row = 8, col = 41 }
                            { module_ =
                                SourcePosition.at
                                    { row = 8, col = 8 }
                                    { row = 8, col = 21 }
                                    "Nested.Module"
                            , args = []
                            , alias = Just "N.M"
                            , expose =
                                AST.Explicit
                                    [ AST.ExposedUpper
                                        { name =
                                            SourcePosition.at
                                                { row = 8, col = 39 }
                                                { row = 8, col = 40 }
                                                "T"
                                        , privacy = AST.Private
                                        }
                                    ]
                                }
                            ]
                    , values = []
                    , unions = []
                    , aliases = []
                    , binops = []
                    , effects = AST.NoEffects
                    }
                )
        , test "imports with arguments" <| \_ ->
            Parser.run PM.parser Context.empty
                """
                module MyModule exposing (..)

                import String
                import Dict String as StrDict
                """
                |> expect
                    (AST.Implementation
                        { name =
                            SourcePosition.at
                                { row = 1, col = 8 }
                                { row = 1, col = 16 }
                                "MyModule"
                        , exports = AST.Open
                        , docs = Nothing
                        , requires = []
                        , imports =
                            [ SourcePosition.at
                                { row = 3, col = 1 }
                                { row = 3, col = 14 }
                                { module_ =
                                    SourcePosition.at
                                        { row = 3, col = 8 }
                                        { row = 3, col = 14 }
                                        "String"
                                , args = []
                                , alias = Nothing
                                , expose = AST.Explicit []
                                }
                            , SourcePosition.at
                                { row = 4, col = 1 }
                                { row = 4, col = 30 }
                                { module_ =
                                    SourcePosition.at
                                        { row = 4, col = 8 }
                                        { row = 4, col = 12 }
                                        "Dict"
                                , args =
                                    [ SourcePosition.at
                                        { row = 4, col = 13 }
                                        { row = 4, col = 19 }
                                        "String"
                                    ]
                                , alias = Just "StrDict"
                                , expose = AST.Explicit []
                                }
                            ]
                        , values = []
                        , unions = []
                        , aliases = []
                        , binops = []
                        , effects = AST.NoEffects
                        }
                    )
        , test "imports with arguments must have alias" <| \_ ->
            Parser.run PM.parser Context.empty
                """
                module MyModule exposing (..)

                import Dict String
                """
                |> expectErr (PM.ExpectedKeyword "as")
        , test "operators" <| \_ ->
            Parser.run PM.parser Context.empty
                """
                module MyModule exposing (..)

                infix left  0 (|>) = apR
                infix right 3 (&&) = and
                infix non   4 (==) = eq
                """
                |> expect
                    (AST.Implementation
                        { name =
                            SourcePosition.at
                                { row = 1, col = 8 }
                                { row = 1, col = 16 }
                                "MyModule"
                        , exports = AST.Open
                        , docs = Nothing
                        , requires = []
                        , imports = []
                        , values = []
                        , unions = []
                        , aliases = []
                        , binops =
                            [ SourcePosition.at
                                { row = 3, col = 1 }
                                { row = 3, col = 25 }
                                { fn = "apR"
                                , symbol = "|>"
                                , associativity = AST.OpALeft
                                , precedence = 0
                                }
                            , SourcePosition.at
                                { row = 4, col = 1 }
                                { row = 4, col = 25 }
                                { fn = "and"
                                , symbol = "&&"
                                , associativity = AST.OpARight
                                , precedence = 3
                                }
                            , SourcePosition.at
                                { row = 5, col = 1 }
                                { row = 5, col = 24 }
                                { fn = "eq"
                                , symbol = "=="
                                , associativity = AST.OpANone
                                , precedence = 4
                                }
                            ]
                         , effects = AST.NoEffects
                         }
                    )
         , test "Module with values, type aliases, unions, and ports" <| \_ ->
             Parser.run PM.parser Context.empty
                 """
                 module MyValues exposing (..)

                 num : Int
                 num = 25

                 type alias Person =
                   { name : String
                   , age : Int
                   }

                 type Choice
                   = Left
                   | Right

                 port somePort : String -> Cmd msg
                 """
                 |> expect
                     (AST.Implementation
                         { name =
                             SourcePosition.at
                                 { row = 1, col = 8 }
                                 { row = 1, col = 16 }
                                 "MyValues"
                         , exports = AST.Open
                         , docs = Nothing
                         , requires = []
                         , imports = []
                         , values =
                          [ SourcePosition.at
                              { row = 3, col = 1 }
                              { row = 4, col = 9 }
                              { docs = Nothing
                              , value =
                                  { name =
                                      SourcePosition.at
                                          { row = 4, col = 1 }
                                          { row = 4, col = 4 }
                                          "num"
                                  , signature =
                                      Just
                                          { start =
                                              { row = 3, col = 1 }
                                          , type_ =
                                              SourcePosition.at
                                                  { row = 3, col = 7 }
                                                  { row = 3, col = 10 }
                                                  (AST.TType
                                                      { name =
                                                          SourcePosition.at
                                                              { row = 3, col = 7 }
                                                              { row = 3, col = 10 }
                                                              "Int"
                                                      , args = []
                                                      }
                                                  )
                                          }
                                  , args = []
                                  , body =
                                      SourcePosition.at
                                          { row = 4, col = 7 }
                                          { row = 4, col = 9 }
                                          (AST.NumberLiteral (Number.Integer 25))
                                  }
                             }
                          ]
                      , unions =
                          [ SourcePosition.at
                              { row = 11, col = 1 }
                              { row = 13, col = 10 }
                              { docs = Nothing
                              , value =
                                 { name =
                                      SourcePosition.at
                                          { row = 11, col = 6 }
                                          { row = 11, col = 12 }
                                          "Choice"
                                  , vars = []
                                  , variants =
                                      [ SourcePosition.at
                                          { row = 12, col = 5 }
                                          { row = 12, col = 9 }
                                          { name =
                                              SourcePosition.at
                                                  { row = 12, col = 5 }
                                                  { row = 12, col = 9 }
                                                  "Left"
