expect : AST.Module -> Result (Array (Parser.DeadEnd c e)) AST.Module -> Expectation
expect expected result =
    when result is
        Err err ->
            Expect.fail (Debug.toString err)

        Ok res ->
            Expect.equal expected res

expectErr : PM.Error -> Result (Array (Parser.DeadEnd c PM.Error)) AST.Module -> Expectation
expectErr expected result =
    when result is
        Ok _ ->
            Expect.fail "Expected error"

        Err problems ->
            when Array.first problems is
                Just firstProblem ->
                    Expect.equal expected firstProblem.problem
                Nothing ->
                    Expect.fail "Expected error but got empty error array"
