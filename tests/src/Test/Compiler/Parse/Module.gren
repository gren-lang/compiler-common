                                                  { row = 13, col = 5 }
                                                  { row = 13, col = 10 }
                                                  "Right"
                                          , payload = Nothing
                                          }
                                      ]
                                  }
                              }
                          ]
                     , aliases =
                         [ SourcePosition.at
                             { row = 6, col = 1 }
                             { row = 9, col = 4 }
                             { docs = Nothing
                             , value =
                                { name =
                                     SourcePosition.at
                                         { row = 6, col = 12 }
                                         { row = 6, col = 18 }
                                         "Person"
                                 , vars = []
                                 , type_ =
                                     SourcePosition.at
                                         { row = 7, col = 3 }
                                         { row = 9, col = 4 }
                                         (AST.TRecord
                                             { fields =
                                                 [ { field =
                                                         SourcePosition.at
                                                             { row = 7, col = 5 }
                                                             { row = 7, col = 9 }
                                                             "name"
                                                     , signature =
                                                         SourcePosition.at
                                                             { row = 7, col = 12 }
                                                             { row = 7, col = 18 }
                                                             (AST.TType
                                                                 { name =
                                                                     SourcePosition.at
                                                                         { row = 7, col = 12 }
                                                                         { row = 7, col = 18 }
                                                                         "String"
                                                                 , args = []
                                                                 }
                                                             )
                                                     }
                                                 , { field =
                                                         SourcePosition.at
                                                             { row = 8, col = 5 }
                                                             { row = 8, col = 8 }
                                                             "age"
                                                     , signature =
                                                         SourcePosition.at
                                                             { row = 8, col = 11 }
                                                             { row = 8, col = 14 }
                                                             (AST.TType
                                                                 { name =
                                                                     SourcePosition.at
                                                                         { row = 8, col = 11 }
                                                                         { row = 8, col = 14 }
                                                                         "Int"
