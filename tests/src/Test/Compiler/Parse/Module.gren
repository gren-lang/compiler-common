                         ]
                    , binops = []
                    , effects =
                        AST.Ports
                            [ SourcePosition.at
                                { row = 15, col = 1 }
                                { row = 15, col = 34}
                                { docs = Nothing
                                , value =
                                    { name =
                                          SourcePosition.at
                                              { row = 15, col = 6 }
                                              { row = 15, col = 14 }
                                              "somePort"
                                    , signature =
                                        SourcePosition.at
                                            { row = 15, col = 17 }
                                            { row = 15, col = 34 }
                                            (AST.TLambda
                                                { from =
