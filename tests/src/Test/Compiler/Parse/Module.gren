         , test "Declaration after when expression" <| \_ ->
             Parser.run PM.parser Context.empty
                 """
                 module Test exposing (..)

                 foo : Int -> String
                 foo n =
                     when n is
                         0 -> "Zero"
                         1 -> "One"
                         _ -> "Other"

                 bar : Int -> String
                 bar n =
                     String.fromInt n
                 """
                 |> expect
                    (AST.Implementation
                        { name =
                            SourcePosition.at
                                { row = 1, col = 8 }
                                { row = 1, col = 12 }
                                "Test"
                        , exports = AST.Open
                        , docs = Nothing
                        , requires = []
                        , imports = []
                        , aliases = []
                        , binops = []
                        , unions = []
                        , effects = AST.NoEffects
                        , values =
                        [ SourcePosition.at
                                { row = 3, col = 1 }
                                { row = 8, col = 21 }
                                { docs = Nothing
                                , value =
                                    { name =
                                        SourcePosition.at
                                            { row = 4, col = 1 }
                                            { row = 4, col = 4 }
                                            "foo"
                                    , signature =
                                        Just
                                            { start =
                                                { row = 3, col = 1 }
                                            , type_ =
                                                SourcePosition.at
                                                    { row = 3, col = 7 }
                                                    { row = 3, col = 20 }
                                                    (AST.TLambda
                                                        { from =
                                                            SourcePosition.at
                                                                { row = 3, col = 7 }
                                                                { row = 3, col = 10 }
                                                                (AST.TType
                                                                    { name =
                                                                        SourcePosition.at
                                                                            { row = 3, col = 7 }
                                                                            { row = 3, col = 10 }
                                                                            "Int"
                                                                    , args = []
                                                                    }
                                                                )
                                                        , to =
                                                            SourcePosition.at
                                                                { row = 3, col = 14 }
